#!/usr/bin/env bash

set -euo pipefail
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/lib/common.sh"

readonly supported_rids=(linux-x64 linux-arm64 osx-x64 osx-arm64 win-x64)
requested="${1:-all}"
linux_x64_packaging_dir="$REPO_ROOT/packaging/linux-x64"
macos_packaging_dir="$REPO_ROOT/packaging/macos"

is_supported_rid() {
    local candidate="$1"
    local rid
    for rid in "${supported_rids[@]}"; do
        [[ "$candidate" == "$rid" ]] && return 0
    done
    return 1
}

if [[ "$requested" == "all" ]]; then
    rids=("${supported_rids[@]}")
elif is_supported_rid "$requested"; then
    rids=("$requested")
else
    printf 'Usage: %s [all|%s]\n' "$0" "$(IFS='|'; echo "${supported_rids[*]}")" >&2
    exit 2
fi

if (( $# > 1 )); then
    printf 'Usage: %s [all|%s]\n' "$0" "$(IFS='|'; echo "${supported_rids[*]}")" >&2
    exit 2
fi

mkdir -p "$ARTIFACTS_DIR/packages" "$ARTIFACTS_DIR/publish"
rm -f "$ARTIFACTS_DIR/SHA256SUMS"

for rid in "${rids[@]}"; do
    publish_dir="$ARTIFACTS_DIR/publish/$rid"
    stage_dir="$ARTIFACTS_DIR/.stage/$rid"
    rm -rf "$publish_dir" "$stage_dir"
    mkdir -p "$publish_dir" "$stage_dir"

    run_quiet "publish $rid" dotnet publish "$APP_PROJECT" \
        -m:1 --nologo --verbosity quiet -c Release -r "$rid" \
        --self-contained true -p:PublishSingleFile=true \
        -o "$publish_dir"

    executable="sheetsmcp"
    [[ "$rid" == win-* ]] && executable="sheetsmcp.exe"
    cp "$publish_dir/$executable" "$stage_dir/$executable"
    cp "$REPO_ROOT/README.md" "$stage_dir/README.md"

    if [[ "$rid" == "linux-x64" ]]; then
        run_quiet "installer syntax linux-x64" bash -n "$linux_x64_packaging_dir/install.sh"
        install -m 0755 "$linux_x64_packaging_dir/install.sh" "$stage_dir/install.sh"
        install -m 0755 "$linux_x64_packaging_dir/Install SheetsMCP.desktop" "$stage_dir/Install SheetsMCP.desktop"
        install -m 0644 "$linux_x64_packaging_dir/INSTALL-linux-x64.md" "$stage_dir/INSTALL-linux-x64.md"
    fi

    if [[ "$rid" == osx-* ]]; then
        run_quiet "installer syntax $rid" bash -n "$macos_packaging_dir/install.sh"
        install -m 0755 "$macos_packaging_dir/install.sh" "$stage_dir/install.sh"
        install -m 0644 "$macos_packaging_dir/INSTALL-macos.md" "$stage_dir/INSTALL-macos.md"
    fi

    if [[ "$rid" == "linux-x64" || "$rid" == osx-* ]]; then
        if [[ -n "${SHEETSMCP_RELEASE_OAUTH_CLIENT_JSON:-}" ]]; then
            if [[ ! -f "$SHEETSMCP_RELEASE_OAUTH_CLIENT_JSON" ]]; then
                printf 'SHEETSMCP_RELEASE_OAUTH_CLIENT_JSON does not exist: %s\n' "$SHEETSMCP_RELEASE_OAUTH_CLIENT_JSON" >&2
                exit 2
            fi

            install -m 0600 "$SHEETSMCP_RELEASE_OAUTH_CLIENT_JSON" "$stage_dir/oauth_client.json"
        fi
    fi

    for license in LICENSE LICENSE.md LICENSE.txt; do
        [[ -f "$REPO_ROOT/$license" ]] && cp "$REPO_ROOT/$license" "$stage_dir/$license"
    done

    if [[ "$rid" == win-* ]]; then
        package="$ARTIFACTS_DIR/packages/sheetsmcp-$rid.zip"
        rm -f "$package"
        run_quiet "package $rid" bash -c \
            'cd "$1" && zip -q -r "$2" .' _ "$stage_dir" "$package"
    else
        package="$ARTIFACTS_DIR/packages/sheetsmcp-$rid.tar.gz"
        rm -f "$package"
        run_quiet "package $rid" tar -czf "$package" -C "$stage_dir" .
    fi
done

rm -rf "$ARTIFACTS_DIR/.stage"

(
    cd "$ARTIFACTS_DIR/packages"
    find . -maxdepth 1 -type f -print0 | sort -z | xargs -0 sha256sum >"$ARTIFACTS_DIR/SHA256SUMS"
)
printf 'OK checksums (%s)\n' "$ARTIFACTS_DIR/SHA256SUMS"
