#!/usr/bin/env bash

set -euo pipefail
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"

default_config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
default_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
oauth_client_config="$default_config_home/sheetsmcp/oauth_client.json"
oauth_token_store="$default_data_home/sheetsmcp/google-oauth"
spreadsheet="${SHEETSMCP_INTEGRATION_SPREADSHEET:-}"

oauth_client_config="$(expand_home "$oauth_client_config")"
if [[ ! -f "$oauth_client_config" ]]; then
    printf 'SKIP integration tests: OAuth client config does not exist: %s\n' "$oauth_client_config"
    exit 0
fi

oauth_token_store="$(expand_home "$oauth_token_store")"
if [[ ! -d "$oauth_token_store" ]]; then
    printf 'SKIP integration tests: OAuth token store does not exist: %s\n' "$oauth_token_store"
    exit 0
fi

if [[ -z "$spreadsheet" ]]; then
    printf 'SKIP integration tests: SHEETSMCP_INTEGRATION_SPREADSHEET is not set\n'
    exit 0
fi

run_quiet "Google read integration test" dotnet test "$TEST_PROJECT" \
    -m:1 --nologo --verbosity quiet -c Release \
    --filter "Category=Integration&Type=Read" \
    --logger "console;verbosity=minimal"

if [[ "${SHEETSMCP_INTEGRATION_WRITE:-}" == "1" ]]; then
    run_quiet "Google write integration test" dotnet test "$TEST_PROJECT" \
        -m:1 --nologo --verbosity quiet -c Release \
        --filter "Category=Integration&Type=Write" \
        --logger "console;verbosity=minimal"
else
    printf 'SKIP Google write integration test: SHEETSMCP_INTEGRATION_WRITE is not 1\n'
fi
